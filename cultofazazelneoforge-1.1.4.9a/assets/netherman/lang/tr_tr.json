  "book.netherman.page1.line1": "Azazel'in Tarikatı §4§lModuna§f§l Hoşgeldiniz!",
  "book.netherman.page1.line2": "İşte modun içeriğine dair kısa bir rehber.",
  "book.netherman.page1.line3": "Oynadığınız için Teşekkürler!",
  "book.netherman.page1.line4": "Yazar: §4Benj1kus",
  "book.netherman.page1.line5": "§c§lAÇIKLAMA:",
  "book.netherman.page1.line6": "Bu mod oyuna yeni yapılar ekler,",
  "book.netherman.page1.line7": "Bu mod daha çok Nether boyutuna odaklanmıştır.",

  "book.netherman.page2.line1": "§c§lYAPILAR: §4§lNether Malikanesi",
  "book.netherman.page2.line2": "Burası 3 bölüme ayrılmış devasa bir malikanedir:",
  "book.netherman.page2.line3": "§6§lLANETLİ TAŞ OCAKLARI",
  "book.netherman.page2.line4": "§c§lKUTSAL ŞEHİR",
  "book.netherman.page2.line5": "§4§lAZAZEL'İN SIĞINAĞI",
  "book.netherman.page2.line6": "§6§lLANETLİ TAŞ OCAKLARI:§f§l Başlangıç bölümü",
  "book.netherman.page2.line7": "Oyuncuların §4Manipülatörler§f§l ile karşılaşacakları bölgedir.",
  "book.netherman.page2.line8": "Onları yenerek köylüleri serbest bırakabilir",
  "book.netherman.page2.line9": "ve ödül kazanabilirsiniz.",

  "book.netherman.page3.line1": "§c§lKUTSAL ŞEHİR:§f§l 2. Bölüm",
  "book.netherman.page3.line2": "Bu keşif odaklı bir bölümdür.",
  "book.netherman.page3.line3": "İki tür NPC bulabilirsiniz:",
  "book.netherman.page3.line4": "§cDoktor§f§l - size rastgele iksirler verir.",
  "book.netherman.page3.line5": "§cDemirci§f§l - Büyüleri yok etmeden",
  "book.netherman.page3.line6": "aletleri söküp tamir edebilir.",
  "book.netherman.page3.line7": "§4§lAZAZEL'İN SIĞINAĞI:§f§l Son bölüm",
  "book.netherman.page3.line8": "Varilin içinde talimatlar bulacaksınız",
  "book.netherman.page3.line9": "bu talimatlar size §4§lAZAZEL'İ§f§l nasıl çağıracağınızı açıklar.",

  "book.netherman.page4.line1": "§c§lNether'daki küçük yapılar",
  "book.netherman.page4.line2": "§2§lOverworld Yapıları",
  "book.netherman.page4.line3": "Boruları bul. Altlarında çatlaklar var. 3 kez ",
  "book.netherman.page4.line4": "Pusula.Sütun.Kafa.Bulmaca.İpuçları İçeride.",
  "book.netherman.page4.line5": "Labirent.Dikkat.Yukarı",
  "book.netherman.page4.line6": "Tanrı?",
  "book.netherman.page4.line7": "2 yol.Tarikat yolu-görevler.Süre 3 gün",

  "book.netherman.page5.line1": "§c§lMOBLAR: §4Ghastly",
  "book.netherman.page5.line2": "Kızıl Köklerden bir kovan yapabilir,",
  "book.netherman.page5.line3": "Kızıl bal yapabilir,",
  "book.netherman.page5.line4": "Evcilleştirilebilir,",
  "book.netherman.page5.line5": "Nether Malikanesine yol gösterebilir.",
  "book.netherman.page5.line6": "§c§lKüçük Rolü Olan Moblar:",
  "book.netherman.page5.line7": "§6Karşılayıcı§f§l - Oyuncuları girişte karşılar.",
  "book.netherman.page5.line8": "§6Tüccar§f§l - çeşitli ticaret seçenekleri sunar.",
  "book.netherman.page5.line9": "§6Yaldızlı Golem§f§l - İnançlıları korur, Kan ve itemleri içine çeker.",
  "book.netherman.page5.line10": "§4Gehinnom§f§l - Bekçi, en iyisi ona sataşmamak.",
  "book.netherman.page5.line11": "§4Manipülatör§f§l - Azazel'in hizmetkarı, kaynakları korur.",

  "book.netherman.page6.line1": "§c§lİTEMLER",
  "book.netherman.page6.line2": "§cYeniden Doğum Totemi:",
  "book.netherman.page6.line3": "Bir oyuncu ölümcül hasar aldığında, onu doğum noktasına ışınlar.",
  "book.netherman.page6.line4": "§4Manipülasyon Asası:",
  "book.netherman.page6.line5": "Manipülasyon efekti uygulamanıza olanak tanır,",
  "book.netherman.page6.line6": "Varlıkları çekip Wither İskeletleri çağırabilirsiniz.",
  "book.netherman.page6.line7": "§e§lOYNADIĞINIZ İÇİN TEŞEKKÜRLER!",
  "book.netherman.page6.line8": "Yazar: §4Benj1kus",

  "boss.netherman.azazel_human.line1": "§6Sen. Kafamı alan adam",
  "boss.netherman.azazel_human.line2": "§6Beni huzura kavuşturan ölümlü",
  "boss.netherman.azazel_human.line3": "§6Yine de sapkınlığından sonra benimle yüzleşmeye cüret ettin",
  "boss.netherman.azazel_human.line4": "§6Gözlerini oymalı ve dilini kesmeliyim",
  "boss.netherman.azazel_human.line5": "§6Ama hayır; Beni etkiledin.",
  "boss.netherman.azazel_human.line6": "§6Bu yüzden sana bir şans vereceğim",
  "boss.netherman.azazel_human.line7": "§6Günahlarının kefaretini ödemen için. Sana lütfedeceğim,",
  "boss.netherman.azazel_human.line8": "§6benim birliğimden olma seçeneğini",
  "boss.netherman.azazel_human.line9": "§6Bu benim merhametimdir",
  "boss.netherman.azazel_human.line10": "§6Öyleyse yaklaş, canavar ve ayaklarıma kapan.",
  "boss.netherman.azazel_human.death_line": "§4ᒲᔑ∷ᔑᔑꖎ ╎ℸ ̣ 'ᓭ ᒲ|| ⎓ᔑ⚍ꖎℸ ̣...",

